"""Main file."""

import logging

from nova.mvvm.trame_binding import TrameBinding
from nova.trame import ThemedApp
{%- if not multitabs %}
from nova.trame.view.components import InputField
from nova.trame.view.layouts import GridLayout
{%- endif %}
from trame.app import get_server

from ..mvvm_factory import create_viewmodels
from ..view_models.main_view_model import MainViewModel
{%- if multitabs %}
from .tab_content_panel import TabContentPanel
from .tabs_panel import TabsPanel
{%- endif %}

logger = logging.getLogger(__name__)
logger.setLevel(logging.INFO)


class MainApp(ThemedApp):
{%- if multitabs %}
    """Main application view class. Calls rendering of nested UI elements."""
{%- else %}
    """Main application view class. Renders all UI elements on the main page."""
{%- endif %}

    def __init__(self) -> None:
        super().__init__()
        self.server = get_server(None, client_type="vue3")
        binding = TrameBinding(self.server.state)
        self.server.state.trame__title = "{{ project_name }}"
        self.view_models = create_viewmodels(binding)
        self.view_model: MainViewModel = self.view_models["main"]
{%- if not multitabs %}
        self.view_model.config_bind.connect("config")
{%- endif %}
        self.create_ui()

    def create_ui(self) -> None:
        self.set_theme("CompactTheme")
        self.state.trame__title = "{{ project_name }}"

        with super().create_ui() as layout:
            layout.toolbar_title.set_text("{{ project_name }}")
            with layout.pre_content:
{%- if multitabs %}
                TabsPanel(self.view_models["main"])
{%- else %}
                pass
{%- endif %}
            with layout.content:
{%- if multitabs %}
                TabContentPanel(
                    self.server,
                    self.view_models["main"],
                )
{%- else %}
                with GridLayout(columns=2, gap="0.25em"):
                    InputField("config.username")
                    InputField("config.password")
{%- endif %}
            with layout.post_content:
                pass
            return layout
